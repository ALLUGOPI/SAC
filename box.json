{
	"id": "com.demo.gauge",
	"version": "1.0.0",
	"name": "Demo Gauge",
	"description": "A high-performance semi-circle gauge widget",
	"newInstancePrefix": "Gauge",
	"icon": "https://mhp-management-und-it.eu10.hcs.cloud.sap/sap/fpa/ui/app.html#/home/box/icon.png",
	"vendor": "Demo",
	"eula": "EULA",
	"license": "1.0",
	"webcomponents": [
		{
			"kind": "main",
			"tag": "com-demo-gauge",
			"url": "https://mhp-management-und-it.eu10.hcs.cloud.sap/sap/fpa/ui/app.html#/home/box.js",
			"integrity": "",
			"ignoreIntegrity": true
		},
		{
			"kind": "styling",
			"tag": "com-demo-gauge-sps",
			"url": "https://mhp-management-und-it.eu10.hcs.cloud.sap/sap/fpa/ui/app.html#/home/box_sps.js",
			"integrity": "",
			"ignoreIntegrity": true
		},
		{
			"kind": "builder",
			"tag": "com-demo-box-bps",
			"url": "https://mhp-management-und-it.eu10.hcs.cloud.sap/sap/fpa/ui/app.html#/home/box_bps.js",
			"integrity": "",
			"ignoreIntegrity": true
		}
	],
	"properties": {
		"value": {
			"type": "number",
			"description": "Current percentage (0-100)",
			"default": 0
		},
		"info": {
			"type": "string",
			"description": "Label displayed below the percentage",
			"default": "Total"
		},
		"color": {
			"type": "string",
			"description": "Primary color for the arc and text",
			"default": "#27ae60"
		},
		"width": {
			"type": "integer",
			"default": 300
		},
		"height": {
			"type": "integer",
			"default": 200
		}
	},
	"methods": {
		"setValue": {
			"description": "Updates all gauge parameters at once.",
			"parameters": [
				{
					"name": "newValue",
					"type": "number"
				},
				{
					"name": "newInfo",
					"type": "string"
				},
				{
					"name": "newColor",
					"type": "string"
				}
			],
			"body": "this.value = newValue; this.info = newInfo; this.color = newColor;"
		},
		"getValue": {
			"returnType": "number",
			"description": "Returns the current gauge value.",
			"body": "return this.value;"
		}
	},
	"events": {
		"onClick": {
			"description": "Fired when the gauge is clicked."
		}
	}
}
